import tensorflow as tf
from tensorflow import keras
from tensorflow.keras import layers
import numpy as np


# Input data
X = np.array([
    [1000, 2, 10],
    [1500, 3, 5],
    [800, 2, 20],
    [2000, 4, 2]
], dtype=float)

y = np.array([200000, 300000, 150000, 400000], dtype=float)


X.max(axis=0)


# Normalize data (important for neural networks)
X_max = X.max(axis=0)
y_max = y.max()

X = X / X_max
y = y / y_max


# Build model
model = keras.Sequential([
    layers.Dense(8, activation='relu', input_shape=(3,)),  # Layer 1
    layers.Dense(4, activation='relu'),                    # Layer 2
    layers.Dense(1)                                        # Output layer
])


model.summary()


# Compile
model.compile(optimizer='adam', loss='mse')


# Train
model.fit(X, y, epochs=100, verbose=0)


model.predict(X)


model.get_weights()


# Predict
test = np.array([[1200, 3, 8]])
test = test / X_max


prediction = model.predict(test)
print(prediction * y_max)



